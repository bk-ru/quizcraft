# Copy to `.env` and adjust for your local environment.
# Real shell variables always take precedence over values in this file.

# --- LM Studio ---
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=google/gemma-4-e2b
# Comma-separated whitelist; defaults to LM_STUDIO_MODEL when omitted.
# LM_STUDIO_ALLOWED_MODELS=google/gemma-4-e2b,qwen2.5-7b-instruct

# --- Backend runtime ---
# Seconds the backend waits for LM Studio. Increase for slow CPU models.
REQUEST_TIMEOUT=300
MAX_FILE_SIZE_MB=10
MAX_DOCUMENT_CHARS=50000

# --- Logging ---
LOG_LEVEL=INFO
# LOG_FORMAT=%(asctime)s %(levelname)s %(name)s %(message)s

# --- Generation profiles (optional JSON) ---
# DEFAULT_GENERATION_PROFILE=balanced
# GENERATION_PROFILES={"balanced": {"inference_parameters": {}}}
